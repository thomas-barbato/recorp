# Skill descriptions
msgid "Enhances thermal weapon systems. Increases thermal damage (up to +25%)"
msgstr "Ameliore les systemes d'armes thermiques. Augmente les degats thermiques (jusqu'a +25%)."

msgid "Optimizes ballistic weapon handling. Increases ballistic accuracy (up to +10%). Increases ballistic damage (up to +25%)"
msgstr "Optimise la maitrise des armes balistiques. Augmente la precision balistique (jusqu'a +10%). Augmente les degats balistiques (jusqu'a +25%)."

msgid "Improves missile weapon systems. Increases missile accuracy (up to +20%). Increases missile damage (up to +25%)"
msgstr "Ameliore les systemes d'armes a missiles. Augmente la precision des missiles (jusqu'a +20%). Augmente les degats des missiles (jusqu'a +25%)."

msgid "Enhances electronic warfare capabilities.  Increases debuff success chance (up to +30%) Increases debuff duration (up to +20%)"
msgstr "Ameliore les capacites de guerre electronique. Augmente les chances de reussite des malus (jusqu'a +30%) et leur duree (jusqu'a +20%)."

msgid "Improves ship maneuverability. Increases evasion chance (up to +20%)\""
msgstr "Ameliore la maniabilite du vaisseau. Augmente les chances d'esquive (jusqu'a +20%)."

msgid "Improves resistance to electronic attacks. Increases resistance to debuffs (up to +30%) Reduces debuff duration (up to -20%)"
msgstr "Ameliore la resistance aux attaques electroniques. Augmente la resistance aux malus (jusqu'a +30%) et reduit leur duree (jusqu'a -20%)."

msgid "Improves onboard repair systems.  Increases repair efficiency (up to +30%)  Reduces repair duration (up to -30%)"
msgstr "Ameliore les systemes de reparation embarques. Augmente l'efficacite des reparations (jusqu'a +30%) et reduit leur duree (jusqu'a -30%)."

msgid "Enhances shield systems. Improves shield damage absorption (up to +20%)"
msgstr "Renforce les systemes de bouclier. Ameliore l'absorption des degats par les boucliers (jusqu'a +20%)."

msgid "Reduces ship signature. Improves stealth and invisibility effectiveness"
msgstr "Reduit la signature du vaisseau. Ameliore l'efficacite de la discretion et de l'invisibilite."

msgid "Improves detection and scanning systems. Improves scan efficiency (up to +30%) Reduces accuracy penalties against unscanned targets"
msgstr "Ameliore les systemes de detection et de scan. Augmente l'efficacite des scans (jusqu'a +30%) et reduit les penalites de precision contre les cibles non scannees."

msgid "Improves weapon accuracy. Increases overall weapon precision (up to +10%)"
msgstr "Ameliore la precision des armes. Augmente la precision globale des armes (jusqu'a +10%)."

